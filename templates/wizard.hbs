<div class="dg-wizard-wrapper">

    {{!-- Progress bar --}}
    <div class="dg-wizard-progress">
        {{#each (range 0 totalSteps)}}
        <div class="dg-step-dot {{#if (eq this ../stepIndex)}}active{{/if}} {{#if (lt this ../stepIndex)}}done{{/if}}">
        </div>
        {{/each}}
        <span class="dg-step-label">Step {{inc stepIndex}} of {{totalSteps}}</span>
    </div>

    <form class="dg-wizard-form" autocomplete="off">

        {{!-- ================================================================
        STEP: welcome
        ================================================================ --}}
        {{#if (eq step "welcome")}}
        <div class="dg-step dg-step-welcome">
            <h2>Welcome, Agent</h2>
            <p class="dg-flavour">
                You've been read in. The Program needs another agent — someone with the skills,
                the bonds, and the will to face what lies beyond. Follow these steps to build
                your character. Nothing you learn here can be unlearned.
            </p>
            <p>
                This wizard will guide you through:<br>
                <strong>Statistics → Profession → Skills → Bonus Skills → Bonds → Biography → Equipment →
                    Review</strong>
            </p>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: stats
        ================================================================ --}}
        {{#if (eq step "stats")}}
        <div class="dg-step dg-step-stats">
            <h2>Statistics</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Distribute <strong>72 points</strong> across your six statistics (min 3, max 18). You can also roll
                    4d6 drop-lowest, or randomize a balanced spread.</p>
                <ul class="dg-tips-list">
                    <li><strong>STR</strong> — Physical strength. Affects melee damage, climb, lift, and some physical
                        skill checks.</li>
                    <li><strong>CON</strong> — Endurance and resilience. Combined with STR to set your Hit Points.</li>
                    <li><strong>DEX</strong> — Agility and coordination. Affects initiative, Dodge, and physical
                        dexterity tasks.</li>
                    <li><strong>INT</strong> — Reason and perception. Many investigative and technical skills derive
                        from INT.</li>
                    <li><strong>POW</strong> — Willpower and psychic force. Sets your Willpower Points and starting
                        Sanity (POW × 5).</li>
                    <li><strong>CHA</strong> — Personality and presence. Your Bond score starts equal to CHA.</li>
                </ul>
                <p><em>HP = ⌈(STR+CON)÷2⌉ &nbsp;|&nbsp; WP = POW &nbsp;|&nbsp; SAN = POW×5</em></p>
            </details>

            <p class="dg-hint">Distribute 72 points across your six statistics (3–18).</p>

            <div class="dg-points-bar">
                Points remaining: <span
                    class="dg-points-remaining{{#if (eq pointsRemaining 0)}} depleted{{/if}}">{{pointsRemaining}}</span>
                / 72
            </div>

            <div class="dg-stats-grid">
                {{#each stats}}
                <div class="dg-stat-block">
                    <label class="dg-stat-label">{{lookup ../statLabels @key}}</label>
                    <div class="dg-stat-controls">
                        <button type="button" data-action="adjustStat" data-stat="{{@key}}" data-delta="-1"
                            class="dg-adjust-btn">−</button>
                        <input type="number" name="stats.{{@key}}" value="{{this}}" min="3" max="18"
                            class="dg-stat-input" />
                        <button type="button" data-action="adjustStat" data-stat="{{@key}}" data-delta="1"
                            class="dg-adjust-btn">+</button>
                    </div>
                    <span class="dg-x5">×5 = {{multiply this 5}}</span>
                    <span class="dg-descriptor">{{lookup ../statDescriptors @key}}</span>
                </div>
                {{/each}}
            </div>

            <div class="dg-stats-actions">
                <button type="button" data-action="rollStats" class="dg-btn-secondary">🎲 Roll All (4d6 drop
                    lowest)</button>
                <button type="button" data-action="randomizeStats" class="dg-btn-secondary">🔀 Randomize (72
                    pts)</button>
                <button type="button" data-action="resetStats" class="dg-btn-secondary">↺ Reset</button>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: profession
        ================================================================ --}}
        {{#if (eq step "profession")}}
        <div class="dg-step dg-step-profession">
            <h2>Profession</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>This is your biggest decision. Profession determines your Agent's skills, role in an operation, and
                    sometimes the resources your Agent can bring to bear by requisitioning equipment.</p>
                <p>A handful of core professions are most frequently seen among Agents: Anthropologist or Historian,
                    Computer Scientist or Engineer, Federal Agent, Physician, Scientist, and Special Operator. Many
                    other professions are described in the Agent's Handbook.</p>
                <p>Each profession provides <em>required skills</em> at fixed values and <em>optional skills</em> you
                    may choose from. After you pick your skills, you'll get <strong>8 background bonus skill
                        picks</strong> (+20 each) to customize further.</p>
            </details>

            <p class="dg-hint">Choose the profession that best fits your agent's background.</p>
            <div class="dg-profession-picker">
                <select name="professionKey" class="dg-select-profession">
                    <option value="">— Select a Profession —</option>
                    {{#each professions}}
                    <option value="{{key}}" {{#if (eq key ../professionKey)}}selected{{/if}}>{{title}}</option>
                    {{/each}}
                </select>
            </div>
            {{#if profession}}
            <div class="dg-profession-desc">
                <pre class="dg-desc-text">{{profession.description}}</pre>
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: skills
        ================================================================ --}}
        {{#if (eq step "skills")}}
        <div class="dg-step dg-step-skills">
            <h2>Skills</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Skills are rated as a percentage. Rolling at or below your skill value is a success.</p>
                <ul class="dg-tips-list">
                    <li><strong>1–19%</strong> — Dabbler: you know the basics but are unreliable.</li>
                    <li><strong>20–39%</strong> — Trained: basic competence; you usually get simple tasks right.</li>
                    <li><strong>40–59%</strong> — Experienced: solid and dependable under normal conditions.</li>
                    <li><strong>60–79%</strong> — Expert: you rarely fail; pressure and opposition are your main
                        threats.</li>
                    <li><strong>80–99%</strong> — Master: a lifetime of dedication. Failure is a genuine surprise.</li>
                </ul>
                <p>Required skills are pre-filled by your profession. Check optional skills (up to the listed limit) to
                    add them at their listed value. In the next step you'll distribute 8 bonus picks of +20 each.</p>
            </details>

            {{#if profession}}
            <p class="dg-hint">
                Professional skills are pre-filled. Choose up to <strong>{{optLimit}}</strong> optional skills.
            </p>
            <p class="dg-opt-picks-counter" data-limit="{{optLimit}}"></p>
            <table class="dg-skills-table">
                <thead>
                    <tr>
                        <th>Skill</th>
                        <th>Base</th>
                        <th>Current</th>
                        <th>Optional?</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each skills}}
                    <tr class="{{#if required}}dg-skill-required{{/if}}{{#if optional}}dg-skill-optional{{/if}}">
                        <td>{{label}}</td>
                        <td class="dg-num">{{base}}</td>
                        <td class="dg-num dg-skill-current">{{current}}</td>
                        <td class="dg-center">
                            {{#if optional}}
                            <input type="checkbox" name="optPick" data-index="{{optIndex}}" {{#if
                                picked}}checked{{/if}} />
                            {{else}}
                            <span class="dg-required-badge">✓</span>
                            {{/if}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            <p class="dg-warn">Please go back and select a profession first.</p>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: bonus_skills
        ================================================================ --}}
        {{#if (eq step "bonus_skills")}}
        <div class="dg-step dg-step-bonus-skills">
            <h2>Bonus Skills</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>You get <strong>8 background skill picks</strong> representing past experience — hobbies, side gigs,
                    a previous career, or extra training.</p>
                <p>Each pick adds <strong>+20%</strong> to a skill. You can assign multiple picks to the same skill
                    but no skill can exceed <strong>80%</strong> during character creation.</p>
                <p>Select a skill for each slot, or leave it empty to skip that pick.</p>
            </details>

            {{#if bonusSkills}}
            <div class="dg-bonus-skills-header">
                <span class="dg-picks-counter">Picks used: <strong>{{bonusSkills.picksUsed}}</strong> / 8</span>
            </div>
            <div class="dg-bonus-slots">
                {{#each bonusSkills.slots}}
                <div class="dg-bonus-slot-row">
                    <label class="dg-bonus-slot-label">Pick {{inc index}}</label>
                    <select name="bonusSlot.{{index}}" class="dg-bonus-slot-select">
                        <option value="">— None —</option>
                        {{#each ../bonusSkills.options}}
                        <option value="{{key}}" {{#if (eq key ../key)}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </select>
                </div>
                {{/each}}
            </div>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: bonds
        ================================================================ --}}
        {{#if (eq step "bonds")}}
        <div class="dg-step dg-step-bonds">
            <h2>Bonds</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Bonds are the personal relationships that keep your agent sane — family members, close friends,
                    romantic partners, trusted colleagues.</p>
                <p>Each Bond starts at your <strong>CHA</strong> value ({{stats.cha}}). Bonds can be damaged when you
                    lose Sanity, and losing a Bond entirely costs additional Sanity. Protect them.</p>
                <p>Your profession allows <strong>{{bondLimit}} bond(s)</strong>. Click 💡 next to any bond for a random
                    suggestion of what kind of relationship this could be.</p>
            </details>

            <p class="dg-hint">
                Your profession permits <strong>{{bondLimit}}</strong> bond(s).
                Bonds start at your CHA score ({{stats.cha}}).
            </p>
            {{#each bonds}}
            <div class="dg-bond-block">
                <div class="dg-bond-row">
                    <span class="dg-bond-num">{{inc @index}}.</span>
                    <input type="text" name="bonds.{{@index}}.name" value="{{name}}" placeholder="Bond name…"
                        class="dg-bond-name" />
                    <label>Score</label>
                    <input type="number" name="bonds.{{@index}}.score" value="{{score}}" min="1" max="99"
                        class="dg-bond-score" />
                    <button type="button" data-action="suggestBond" data-index="{{@index}}" class="dg-btn-small"
                        title="Suggest a bond">💡</button>
                    <button type="button" data-action="removeBond" data-index="{{@index}}"
                        class="dg-btn-small dg-btn-danger" title="Remove">✕</button>
                </div>
                {{#if relationship}}
                <div class="dg-bond-details">
                    <span class="dg-bond-relationship">{{relationship}}</span>
                    {{#if description}}
                    <p class="dg-bond-description">{{description}}</p>
                    {{/if}}
                </div>
                {{/if}}
            </div>
            {{/each}}
            {{#unless bondsAtLimit}}
            <button type="button" data-action="addBond" class="dg-btn-secondary">+ Add Bond</button>
            {{/unless}}
            {{#if bondsAtLimit}}
            <p class="dg-warn">Maximum bonds reached for this profession.</p>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: biography
        ================================================================ --}}
        {{#if (eq step "biography")}}
        <div class="dg-step dg-step-biography">
            <h2>Biography</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Fill in who your agent is — their name, background, and physical appearance. All fields are optional
                    but bring your character to life on the sheet.</p>
                <p>Click <strong>Random Bio</strong> to auto-generate a name and physical description based on your
                    stats and profession. You can always edit the result afterward.</p>
            </details>

            <div class="dg-bio-actions">
                <button type="button" data-action="randomBio" class="dg-btn-secondary">🎲 Random Bio</button>
            </div>

            <div class="dg-bio-grid">
                <label class="dg-bio-full-row">Agent Name
                    <input type="text" name="biography.name" value="{{biography.name}}"
                        placeholder="First and last name" />
                </label>
                <label>Profession / Job Title
                    <input type="text" name="biography.profession" value="{{biography.profession}}"
                        placeholder="e.g. FBI Special Agent" />
                </label>
                <label>Employer
                    <input type="text" name="biography.employer" value="{{biography.employer}}"
                        placeholder="e.g. Federal Bureau of Investigation" />
                </label>
                <label>Nationality
                    <input type="text" name="biography.nationality" value="{{biography.nationality}}"
                        placeholder="e.g. American" />
                </label>
                <label>Sex
                    <input type="text" name="biography.sex" value="{{biography.sex}}"
                        placeholder="e.g. Male / Female / Non-binary" />
                </label>
                <label>Age
                    <input type="text" name="biography.age" value="{{biography.age}}" placeholder="e.g. 34" />
                </label>
                <label>Education
                    <input type="text" name="biography.education" value="{{biography.education}}"
                        placeholder="e.g. BA Criminology, Quantico" />
                </label>
                <label class="dg-bio-full-row">Physical Description
                    <textarea name="biography.physicalDescription" rows="3"
                        placeholder="Build, height, hair, eyes, notable features…">{{biography.physicalDescription}}</textarea>
                </label>

                <fieldset class="dg-bio-full-row dg-motivations-block">
                    <legend>Motivations (up to 5)</legend>
                    {{#each motivations}}
                    <input type="text" name="motivation.{{@index}}" value="{{this}}"
                        placeholder="e.g. Protect my family, Uncover the truth…" />
                    {{/each}}
                </fieldset>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: equipment
        ================================================================ --}}
        {{#if (eq step "equipment")}}
        <div class="dg-step dg-step-equipment">
            <h2>Equipment</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Select gear for your agent. Operational mission equipment is issued and returned; personal gear
                    belongs to the agent.</p>
                <p>Expense levels:</p>
                <ul class="dg-tips-list">
                    <li><span class="dg-exp-badge dg-exp-incidental">Incidental</span> — Freely available; negligible
                        cost.</li>
                    <li><span class="dg-exp-badge dg-exp-standard">Standard</span> — Normal consumer purchase.</li>
                    <li><span class="dg-exp-badge dg-exp-unusual">Unusual</span> — Difficult to source legally; requires
                        effort.</li>
                    <li><span class="dg-exp-badge dg-exp-major">Major</span> — Significant expense or official channels
                        required.</li>
                    <li><span class="dg-exp-badge dg-exp-extreme">Extreme</span> — Rare, heavy, or highly restricted.
                    </li>
                </ul>
                <p>Items marked <strong>RESTRICTED</strong> require Program authorization or special legal access.</p>
            </details>

            <div class="dg-eq-layout">
                <div class="dg-eq-left">
                    <div class="dg-eq-search-row">
                        <input type="text" id="dg-eq-search" class="dg-eq-search-input" placeholder="Search catalog…" />
                        <span class="dg-eq-count"></span>
                    </div>
                    <div id="dg-eq-cat-tabs" class="dg-eq-cat-tabs"></div>
                    <div id="dg-eq-catalog" class="dg-eq-catalog"></div>
                </div>
                <div class="dg-eq-right">
                    <div class="dg-eq-loadout-header">
                        Loadout
                        {{#if equipmentCount}}<span class="dg-eq-loadout-badge">{{equipmentCount}}</span>{{/if}}
                    </div>
                    <div id="dg-eq-loadout" class="dg-eq-loadout"></div>
                    <button type="button" data-action="clearEquipment" class="dg-btn-secondary dg-eq-clear-btn">✕ Clear
                        Loadout</button>
                </div>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: review
        ================================================================ --}}
        {{#if (eq step "review")}}
        <div class="dg-step dg-step-review">
            <h2>Review &amp; Confirm</h2>
            <p class="dg-hint">Verify your agent before committing changes to the actor sheet.</p>

            <section class="dg-review-section">
                <h3>Statistics</h3>
                <div class="dg-stats-grid dg-stats-readonly">
                    {{#each review.stats}}
                    <div class="dg-stat-block">
                        <span class="dg-stat-label">{{label}}</span>
                        <span class="dg-stat-value">{{value}}</span>
                        <span class="dg-x5">×5 = {{x5}}</span>
                    </div>
                    {{/each}}
                </div>
            </section>

            <section class="dg-review-section">
                <h3>Profession</h3>
                <p>{{review.profession}}</p>
            </section>

            <section class="dg-review-section">
                <h3>Key Skills</h3>
                <div class="dg-review-skills">
                    {{#each review.skills}}
                    <span class="dg-review-skill">{{label}}: <strong>{{value}}%</strong></span>
                    {{/each}}
                </div>
            </section>

            <section class="dg-review-section">
                <h3>Bonds</h3>
                {{#each review.bonds}}
                <div class="dg-review-bond">{{name}} ({{score}})</div>
                {{/each}}
                {{#unless review.bonds}}
                <p class="dg-warn">No bonds defined.</p>
                {{/unless}}
            </section>

            <section class="dg-review-section">
                <h3>Biography</h3>
                <div class="dg-review-bio-grid">
                    {{#each review.biography}}
                    <span class="dg-review-bio-key">{{label}}</span>
                    <span class="dg-review-bio-val">{{value}}</span>
                    {{/each}}
                </div>
            </section>

            {{#if review.motivations.length}}
            <section class="dg-review-section">
                <h3>Motivations</h3>
                <ul class="dg-review-motivations">
                    {{#each review.motivations}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
            </section>
            {{/if}}

            {{#each review.bonusAllocations}}
            {{#if @first}}
            <section class="dg-review-section">
                <h3>Bonus Skill Picks</h3>
                <div class="dg-review-skills">
            {{/if}}
                    <span class="dg-review-skill">{{label}}: <strong>+{{total}}%</strong></span>
            {{#if @last}}
                </div>
            </section>
            {{/if}}
            {{/each}}

            {{#if review.equipment.length}}
            <section class="dg-review-section">
                <h3>Equipment ({{review.equipment.length}} items)</h3>
                <div class="dg-review-equipment">
                    {{#each review.equipment}}
                    <span class="dg-review-eq-item">{{this}}</span>
                    {{/each}}
                </div>
            </section>
            {{/if}}
        </div>
        {{/if}}

    </form>{{!-- .dg-wizard-form --}}

    {{!-- Navigation --}}
    <div class="dg-wizard-nav">
        {{#unless isFirst}}
        <button type="button" data-action="prevStep" class="dg-btn-secondary">← Back</button>
        {{/unless}}
        <span class="dg-nav-spacer"></span>
        {{#if isLast}}
        <button type="button" data-action="finish" class="dg-btn-primary dg-btn-finish">✔ Apply to Sheet</button>
        {{else}}
        <button type="button" data-action="nextStep" class="dg-btn-primary">Next →</button>
        {{/if}}
    </div>

</div>{{!-- .dg-wizard-wrapper --}}